---
interface Props {
  title: string;
  description: string;
  date: Date;
  category: string;
  tags: string[];
  slug: string;
}

const { title, description, date, category, tags, slug } = Astro.props;
const formattedDate = date.toISOString().split('T')[0];
---

<a href={`/blog/${slug}`} class="card group block">
  <div class="flex items-start gap-4 sm:gap-6">
    <time class="text-sm font-mono text-[var(--color-text-secondary)] shrink-0 pt-0.5">
      {formattedDate}
    </time>
    <div class="flex-1 min-w-0">
      <h2 class="text-lg font-semibold group-hover:text-primary transition-colors">
        {title}
      </h2>
      <p class="text-sm text-[var(--color-text-secondary)] mt-1 line-clamp-2">
        {description}
      </p>
      <div class="flex flex-wrap items-center gap-2 mt-3">
        <span class="px-3 py-1 rounded-full text-xs font-medium bg-primary/10 text-primary">
          {category}
        </span>
        {tags.map(tag => (
          <span class="px-2 py-1 rounded-full text-xs text-[var(--color-text-secondary)] bg-[var(--color-bg)] border border-[var(--color-border)]">
            {tag}
          </span>
        ))}
      </div>
    </div>
  </div>
</a>
