---
const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--color-border)] mt-16" style="background-color: var(--color-bg-card);">
  <div class="mx-auto max-w-6xl px-5 py-8 flex flex-col items-center gap-3 text-center" style="font-family: var(--font-mono);">
    <p class="text-xs text-[var(--color-text-secondary)]">
      <span style="color: var(--color-accent); opacity: 0.7;">✦</span>
      &nbsp;xmin<span class="text-[var(--color-accent)]">.</span>blog&nbsp;
      <span style="color: var(--color-accent); opacity: 0.7;">·</span>
      &nbsp;보안 · AI · 개발&nbsp;
      <span style="color: var(--color-accent); opacity: 0.7;">✦</span>
    </p>
    <p class="text-xs text-[var(--color-text-secondary)]">
      <span style="color: var(--color-accent); opacity: 0.7;">//</span> &copy; {year} 주수민 (xmin)
      <span class="mx-2 text-[var(--color-border)]">|</span>
      <a href="https://github.com/xmin-02" target="_blank" rel="noopener" class="hover:text-[var(--color-accent)] transition-colors">github</a>
      <span class="mx-2 text-[var(--color-border)]">|</span>
      <a href="https://xmin.sh" target="_blank" rel="noopener" class="hover:text-[var(--color-accent)] transition-colors">portfolio</a>
    </p>
  </div>
</footer>
