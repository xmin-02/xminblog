---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Admin — xmin.blog" description="Blog analytics dashboard">
  <div class="mx-auto max-w-6xl px-4 sm:px-5 py-10">
    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-2xl font-bold tracking-tight" style="font-family:var(--font-display);">Analytics</h1>
        <p class="text-xs text-[var(--color-text-secondary)] mt-1" style="font-family:var(--font-mono);">// 블로그 통계 대시보드</p>
      </div>
      <div class="flex items-center gap-2">
        <a href="/post#new"
          class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-md text-xs font-semibold transition-opacity"
          style="background:var(--color-accent);color:white;font-family:var(--font-mono);">+ new post</a>
      </div>
    </div>

    <!-- Loading -->
    <div id="adm-loading" class="text-center py-20 text-[var(--color-text-secondary)]">
      <div class="inline-block w-6 h-6 border-2 border-[var(--color-accent)] border-t-transparent rounded-full animate-spin mb-3"></div>
      <p class="text-sm">통계 로딩 중...</p>
    </div>

    <!-- Forbidden -->
    <div id="adm-forbidden" class="hidden text-center py-16">
      <p class="text-base mb-4">관리자만 접근 가능합니다.</p>
      <a href="/login" class="inline-block px-4 py-2 rounded-md text-sm font-semibold" style="background:var(--color-accent);color:white;">로그인</a>
    </div>

    <!-- Dashboard -->
    <div id="adm-content" class="hidden space-y-6">
      <!-- Summary cards -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3" id="adm-summary"></div>

      <!-- Posts breakdown -->
      <div class="adm-card">
        <p class="adm-card-title">// posts</p>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3" id="adm-posts-breakdown"></div>
      </div>

      <!-- 30-day views -->
      <div class="adm-card">
        <p class="adm-card-title">// views (last 30 days)</p>
        <div id="adm-views-chart" class="adm-chart"></div>
        <p id="adm-views-empty" class="hidden text-xs text-[var(--color-text-secondary)] text-center py-6">아직 페이지뷰 데이터가 없습니다.</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Top by views -->
        <div class="adm-card">
          <p class="adm-card-title">// top — views</p>
          <div id="adm-top-views"></div>
        </div>

        <!-- Top by likes -->
        <div class="adm-card">
          <p class="adm-card-title">// top — likes</p>
          <div id="adm-top-likes"></div>
        </div>

        <!-- Top by comments -->
        <div class="adm-card">
          <p class="adm-card-title">// top — comments</p>
          <div id="adm-top-comments"></div>
        </div>

        <!-- Categories -->
        <div class="adm-card">
          <p class="adm-card-title">// categories</p>
          <div id="adm-categories"></div>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Recent comments -->
        <div class="adm-card">
          <p class="adm-card-title">// recent comments</p>
          <div id="adm-recent-comments" class="space-y-2"></div>
        </div>

        <!-- Recent users -->
        <div class="adm-card">
          <p class="adm-card-title">// recent users</p>
          <div id="adm-recent-users" class="space-y-2"></div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style is:global>
  @keyframes spin { to { transform: rotate(360deg); } }
  .animate-spin { animation: spin 0.8s linear infinite; }

  .adm-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 0.625rem;
    padding: 1.25rem 1.4rem;
  }
  .adm-card-title {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
    padding-bottom: 0.625rem;
    border-bottom: 1px solid var(--color-border);
  }
  .adm-stat {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 0.625rem;
    padding: 0.95rem 1.1rem;
  }
  .adm-stat-label {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--color-text-secondary);
    text-transform: lowercase;
  }
  .adm-stat-value {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.1;
    margin-top: 0.2rem;
  }
  .adm-stat-sub {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-text-secondary);
    margin-top: 0.3rem;
  }

  .adm-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--color-border);
    font-size: 0.825rem;
  }
  .adm-row:last-child { border-bottom: none; }
  .adm-row-rank {
    font-family: var(--font-mono);
    color: var(--color-text-secondary);
    font-size: 0.7rem;
    width: 1.3rem;
    flex-shrink: 0;
  }
  .adm-row-title {
    flex: 1;
    min-width: 0;
    color: var(--color-text);
    text-decoration: none;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    transition: color 0.15s;
  }
  .adm-row-title:hover { color: var(--color-accent); }
  .adm-row-num {
    font-family: var(--font-mono);
    color: var(--color-accent);
    font-weight: 600;
    font-size: 0.78rem;
    flex-shrink: 0;
  }
  .adm-row-bar-wrap {
    flex: 1;
    height: 6px;
    background: var(--color-bg-secondary);
    border-radius: 3px;
    overflow: hidden;
    margin: 0 0.5rem;
  }
  .adm-row-bar {
    height: 100%;
    background: linear-gradient(90deg, var(--color-accent), var(--color-accent-bright, var(--color-accent)));
    border-radius: 3px;
  }

  .adm-chart {
    display: flex;
    align-items: flex-end;
    gap: 3px;
    height: 100px;
    padding-top: 0.5rem;
  }
  .adm-chart-bar {
    flex: 1;
    background: var(--color-accent);
    opacity: 0.85;
    border-radius: 2px 2px 0 0;
    min-height: 2px;
    position: relative;
    transition: opacity 0.15s;
  }
  .adm-chart-bar:hover { opacity: 1; }
  .adm-chart-bar[data-tip]:hover::after {
    content: attr(data-tip);
    position: absolute;
    bottom: 100%;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-bg-card);
    color: var(--color-text);
    border: 1px solid var(--color-border);
    padding: 0.25rem 0.5rem;
    border-radius: 0.3rem;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    white-space: nowrap;
    pointer-events: none;
    z-index: 10;
  }

  .adm-comment {
    padding: 0.6rem 0.75rem;
    border-radius: 0.5rem;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
  }
  .adm-comment-meta {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--color-text-secondary);
    margin-bottom: 0.35rem;
  }
  .adm-comment-link {
    color: var(--color-accent);
    text-decoration: none;
  }
  .adm-comment-link:hover { text-decoration: underline; }

  .adm-empty {
    text-align: center;
    padding: 2rem 0;
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }
</style>

<script is:inline>
  const API_BASE = 'https://api.xmin.blog';

  function esc(s) {
    return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function fmtNum(n) {
    return Number(n || 0).toLocaleString('ko-KR');
  }

  async function admInit() {
    const token = localStorage.getItem('auth_token');
    let user = null;
    try { user = JSON.parse(localStorage.getItem('auth_user') || 'null'); } catch {}
    if (!token || !user || user.role !== 'admin') {
      document.getElementById('adm-loading').classList.add('hidden');
      document.getElementById('adm-forbidden').classList.remove('hidden');
      return;
    }
    try {
      const res = await fetch(`${API_BASE}/api/admin/stats`, {
        headers: { Authorization: `Bearer ${token}` },
      });
      if (res.status === 403 || res.status === 401) {
        document.getElementById('adm-loading').classList.add('hidden');
        document.getElementById('adm-forbidden').classList.remove('hidden');
        return;
      }
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const stats = await res.json();
      document.getElementById('adm-loading').classList.add('hidden');
      document.getElementById('adm-content').classList.remove('hidden');
      render(stats);
    } catch (err) {
      document.getElementById('adm-loading').innerHTML = `<p class="text-sm" style="color:#ef4444;">로딩 실패: ${esc(err.message)}</p>`;
    }
  }

  function render(stats) {
    renderSummary(stats.summary);
    renderPostsBreakdown(stats.summary);
    renderViewsChart(stats.views_by_day || []);
    renderTopList('adm-top-views', stats.top_by_views, 'views');
    renderTopList('adm-top-likes', stats.top_by_likes, 'likes');
    renderTopList('adm-top-comments', stats.top_by_comments, 'comments');
    renderCategories(stats.categories || []);
    renderRecentComments(stats.recent_comments || []);
    renderRecentUsers(stats.recent_users || []);
  }

  function renderSummary(s) {
    const el = document.getElementById('adm-summary');
    el.innerHTML = [
      ['views',    s.total_views,    `${fmtNum(s.published_posts)} published`],
      ['likes',    s.total_likes,    `${fmtNum(s.total_users)} users`],
      ['comments', s.total_comments, ''],
      ['posts',    s.total_posts,    `${fmtNum(s.private_posts)} private · ${fmtNum(s.draft_posts)} draft`],
    ].map(([label, val, sub]) => `
      <div class="adm-stat">
        <p class="adm-stat-label">// ${esc(label)}</p>
        <p class="adm-stat-value">${fmtNum(val)}</p>
        ${sub ? `<p class="adm-stat-sub">${esc(sub)}</p>` : ''}
      </div>
    `).join('');
  }

  function renderPostsBreakdown(s) {
    const el = document.getElementById('adm-posts-breakdown');
    el.innerHTML = [
      ['total',     s.total_posts],
      ['published', s.published_posts],
      ['drafts',    s.draft_posts],
      ['private',   s.private_posts],
    ].map(([label, val]) => `
      <div>
        <p class="adm-stat-label">// ${esc(label)}</p>
        <p class="adm-stat-value" style="font-size:1.3rem;">${fmtNum(val)}</p>
      </div>
    `).join('');
  }

  function renderViewsChart(byDay) {
    const el = document.getElementById('adm-views-chart');
    const empty = document.getElementById('adm-views-empty');
    // Build last-30-day window
    const days = [];
    const today = new Date();
    today.setHours(0,0,0,0);
    for (let i = 29; i >= 0; i--) {
      const d = new Date(today);
      d.setDate(d.getDate() - i);
      const key = d.toISOString().slice(0, 10);
      days.push(key);
    }
    const lookup = Object.fromEntries(byDay.map(r => [r.day, r.views]));
    const max = Math.max(1, ...days.map(d => lookup[d] || 0));
    if (max === 1 && byDay.length === 0) {
      el.innerHTML = '';
      empty.classList.remove('hidden');
      return;
    }
    empty.classList.add('hidden');
    el.innerHTML = days.map(d => {
      const v = lookup[d] || 0;
      const h = (v / max) * 100;
      return `<div class="adm-chart-bar" style="height:${h}%;" data-tip="${d}: ${v}"></div>`;
    }).join('');
  }

  function renderTopList(elId, rows, key) {
    const el = document.getElementById(elId);
    if (!rows || !rows.length) { el.innerHTML = '<p class="adm-empty">아직 데이터 없음</p>'; return; }
    const max = Math.max(...rows.map(r => Number(r[key] || 0)));
    el.innerHTML = rows.map((r, i) => {
      const v = Number(r[key] || 0);
      const pct = max > 0 ? (v / max) * 100 : 0;
      return `<div class="adm-row">
        <span class="adm-row-rank">${i + 1}.</span>
        <a href="/post#${esc(r.post_slug)}" class="adm-row-title" title="${esc(r.title)}">${esc(r.title)}</a>
        <span class="adm-row-bar-wrap"><span class="adm-row-bar" style="width:${pct}%"></span></span>
        <span class="adm-row-num">${fmtNum(v)}</span>
      </div>`;
    }).join('');
  }

  function renderCategories(rows) {
    const el = document.getElementById('adm-categories');
    if (!rows.length) { el.innerHTML = '<p class="adm-empty">카테고리 없음</p>'; return; }
    const max = Math.max(...rows.map(r => Number(r.count || 0)));
    el.innerHTML = rows.map(r => {
      const v = Number(r.count || 0);
      const pct = (v / max) * 100;
      return `<div class="adm-row">
        <a href="/?category=${encodeURIComponent(r.category)}" class="adm-row-title">[${esc(r.category)}]</a>
        <span class="adm-row-bar-wrap"><span class="adm-row-bar" style="width:${pct}%"></span></span>
        <span class="adm-row-num">${fmtNum(v)}</span>
      </div>`;
    }).join('');
  }

  function renderRecentComments(rows) {
    const el = document.getElementById('adm-recent-comments');
    if (!rows.length) { el.innerHTML = '<p class="adm-empty">댓글 없음</p>'; return; }
    el.innerHTML = rows.map(c => {
      const date = new Date(Number(c.created_at) * 1000).toLocaleString('ko-KR');
      const preview = (c.content || '').slice(0, 80);
      return `<div class="adm-comment">
        <div class="adm-comment-meta">
          <strong style="color:var(--color-text);">${esc(c.nickname || '익명')}</strong>
          on <a class="adm-comment-link" href="/post#${esc(c.post_slug)}">${esc(c.post_slug)}</a>
          · ${esc(date)}
        </div>
        <p class="text-sm" style="color:var(--color-text);line-height:1.5;">${esc(preview)}${c.content && c.content.length > 80 ? '…' : ''}</p>
      </div>`;
    }).join('');
  }

  function renderRecentUsers(rows) {
    const el = document.getElementById('adm-recent-users');
    if (!rows.length) { el.innerHTML = '<p class="adm-empty">사용자 없음</p>'; return; }
    el.innerHTML = rows.map(u => {
      const date = new Date(Number(u.created_at) * 1000).toLocaleDateString('ko-KR');
      const roleBadge = u.role === 'admin'
        ? '<span style="color:var(--color-accent);font-family:var(--font-mono);font-size:0.65rem;">[admin]</span>'
        : '<span style="color:var(--color-text-secondary);font-family:var(--font-mono);font-size:0.65rem;">[user]</span>';
      return `<div class="adm-comment">
        <div class="adm-comment-meta">
          <strong style="color:var(--color-text);">${esc(u.nickname || '?')}</strong>
          ${roleBadge} · ${esc(date)}
        </div>
        <p class="text-xs" style="color:var(--color-text-secondary);font-family:var(--font-mono);">${esc(u.email)}</p>
      </div>`;
    }).join('');
  }

  admInit();
</script>