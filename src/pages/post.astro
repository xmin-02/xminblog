---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="xmin.blog">
  <div class="mx-auto max-w-6xl px-4 sm:px-5 py-8">
    <div class="flex gap-7 items-start">

      <!-- ===== ARTICLE AREA ===== -->
      <main class="flex-1 min-w-0">
        <div id="post-container">
          <div class="text-center py-20 text-[var(--color-text-secondary)]" id="post-loading">
            <div class="inline-block w-6 h-6 border-2 border-[var(--color-accent)] border-t-transparent rounded-full animate-spin mb-3"></div>
            <p class="text-sm">글을 불러오는 중...</p>
          </div>
        </div>

        <!-- Comments section (populated after post loads) -->
        <div id="comments-section" class="hidden mt-12 pt-8 border-t border-[var(--color-border)]">
          <h2 class="text-base font-bold mb-6" style="font-family:var(--font-display);color:var(--color-text);">댓글</h2>

          <!-- Comment form -->
          <div id="comment-form-area" class="mb-8"></div>

          <!-- Comment list -->
          <div id="comment-list" class="space-y-4"></div>
        </div>
      </main>

      <!-- ===== SIDEBAR ===== -->
      <aside class="w-64 shrink-0 hidden lg:block sticky top-20">

        <!-- Profile card -->
        <div class="sidebar-widget">
          <div class="flex flex-col items-center text-center py-2">
            <div class="w-14 h-14 rounded-full flex items-center justify-center text-white text-lg font-bold mb-2.5" style="background: linear-gradient(135deg, #0d9488, #0f766e);">
              x
            </div>
            <p class="font-bold text-[var(--color-text)] text-sm">주수민 <span class="font-normal text-[var(--color-text-secondary)]">/ xmin</span></p>
            <p class="text-xs text-[var(--color-text-secondary)] mt-0.5">보안 · AI</p>
            <a href="/" class="mt-3 text-xs px-3 py-1.5 rounded-lg font-medium transition-colors" style="background:rgba(13,148,136,0.1);color:var(--color-accent);">
              글 목록 보기
            </a>
          </div>
        </div>

        <!-- Table of contents -->
        <div class="sidebar-widget" id="toc-widget" style="display:none;">
          <p class="sidebar-widget-title">목차</p>
          <nav id="toc-nav" class="space-y-1 text-xs"></nav>
        </div>

        <!-- Recent posts -->
        <div class="sidebar-widget">
          <p class="sidebar-widget-title">최근 글</p>
          <ul id="sidebar-recent" class="space-y-2.5">
            <li class="text-xs text-[var(--color-text-secondary)]">불러오는 중...</li>
          </ul>
        </div>

      </aside>
    </div>
  </div>
</BaseLayout>

<style is:global>
  @keyframes spin { to { transform: rotate(360deg); } }
  .animate-spin { animation: spin 0.8s linear infinite; }

  .post-nav-link {
    display: flex; flex-direction: column; gap: 0.25rem;
    padding: 0.875rem 1rem; border-radius: 0.625rem;
    background-color: var(--color-bg-card);
    box-shadow: var(--shadow-card);
    transition: box-shadow 0.2s, transform 0.15s;
    text-decoration: none; color: inherit; flex: 1; min-width: 0;
  }
  .post-nav-link:hover { box-shadow: var(--shadow-hover); transform: translateY(-1px); }
  .post-nav-label { font-size: 0.7rem; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; color: var(--color-text-secondary); }
  .post-nav-title { font-size: 0.875rem; font-weight: 600; color: var(--color-text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; transition: color 0.15s; }
  .post-nav-link:hover .post-nav-title { color: var(--color-accent); }

  .toc-link { display: block; padding: 0.2rem 0.5rem; border-radius: 0.35rem; color: var(--color-text-secondary); text-decoration: none; transition: color 0.15s, background-color 0.15s; line-height: 1.4; }
  .toc-link:hover, .toc-link.active { color: var(--color-accent); background-color: rgba(13,148,136,0.08); }
  .toc-h3 { padding-left: 1rem; font-size: 0.7rem; }
  .toc-h2 { font-size: 0.75rem; font-weight: 500; }

  .like-btn { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.5rem 1rem; border-radius: 2rem; font-size: 0.8125rem; font-weight: 600; border: 1.5px solid var(--color-border); background: var(--color-bg-card); color: var(--color-text-secondary); cursor: pointer; transition: all 0.15s; }
  .like-btn:hover { border-color: #f43f5e; color: #f43f5e; }
  .like-btn.liked { border-color: #f43f5e; color: #f43f5e; background: rgba(244,63,94,0.06); }

  .comment-card { padding: 0.875rem 1rem; border-radius: 0.75rem; background: var(--color-bg-card); box-shadow: var(--shadow-card); }
  .comment-textarea { width: 100%; padding: 0.75rem; border-radius: 0.625rem; border: 1px solid var(--color-border); background: var(--color-bg-secondary); color: var(--color-text); font-size: 0.875rem; resize: vertical; min-height: 80px; font-family: var(--font-sans); transition: border-color 0.15s; outline: none; }
  .comment-textarea:focus { border-color: var(--color-accent); }
  .comment-submit { padding: 0.5rem 1.25rem; border-radius: 0.5rem; font-size: 0.8125rem; font-weight: 600; color: white; border: none; cursor: pointer; transition: opacity 0.15s; background: linear-gradient(135deg, #0d9488, #0f766e); }
  .comment-submit:hover { opacity: 0.9; }
  .comment-submit:disabled { opacity: 0.5; cursor: not-allowed; }
</style>

<script is:inline>
  const API_BASE = 'https://blog-api.aidi1030.workers.dev';

  function esc(str) {
    return String(str ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function renderMarkdown(md) {
    let html = md.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    html = html.replace(/```(\w*)\n([\s\S]*?)```/g, (_, lang, code) =>
      `<pre><code class="language-${lang || 'text'}">${code.trimEnd()}</code></pre>`);
    html = html.replace(/`([^`]+)`/g, '<code>$1</code>');
    html = html.replace(/!\[([^\]]*)\]\(([^)]+)\)/g, '<img src="$2" alt="$1" />');
    html = html.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener">$1</a>');
    html = html.replace(/^#### (.+)$/gm, '<h4>$1</h4>');
    html = html.replace(/^### (.+)$/gm, '<h3>$1</h3>');
    html = html.replace(/^## (.+)$/gm, '<h2>$1</h2>');
    html = html.replace(/^# (.+)$/gm, '<h1>$1</h1>');
    html = html.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
    html = html.replace(/\*([^*]+)\*/g, '<em>$1</em>');
    html = html.replace(/^&gt; (.+)$/gm, '<blockquote>$1</blockquote>');
    html = html.replace(/^---$/gm, '<hr>');
    return html.split(/\n{2,}/).map(block => {
      const t = block.trim();
      if (!t) return '';
      if (/^<(h[1-6]|pre|blockquote|hr|img)/.test(t)) return t;
      const listLines = t.split('\n');
      if (listLines.every(l => /^[-*] /.test(l) || !l.trim())) {
        return '<ul>' + listLines.map(l => { const m = l.match(/^[-*] (.+)/); return m ? `<li>${m[1]}</li>` : ''; }).join('') + '</ul>';
      }
      if (listLines.every(l => /^\d+\. /.test(l) || !l.trim())) {
        return '<ol>' + listLines.map(l => { const m = l.match(/^\d+\. (.+)/); return m ? `<li>${m[1]}</li>` : ''; }).join('') + '</ol>';
      }
      return '<p>' + t.replace(/\n/g, '<br>') + '</p>';
    }).join('\n');
  }

  function buildToc(container) {
    const headings = container.querySelectorAll('h2, h3');
    if (headings.length < 2) return;
    const tocWidget = document.getElementById('toc-widget');
    const tocNav = document.getElementById('toc-nav');
    if (!tocWidget || !tocNav) return;
    tocWidget.style.display = '';
    let idCounter = 0;
    const links = [];
    headings.forEach(h => {
      const id = `heading-${++idCounter}`;
      h.id = id;
      const a = document.createElement('a');
      a.href = `#${id}`;
      a.className = `toc-link ${h.tagName === 'H3' ? 'toc-h3' : 'toc-h2'}`;
      a.textContent = h.textContent;
      tocNav.appendChild(a);
      links.push({ el: h, a });
    });
    const obs = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        const link = links.find(l => l.el === entry.target);
        if (link) link.a.classList.toggle('active', entry.isIntersecting);
      });
    }, { rootMargin: '-10% 0px -80% 0px' });
    headings.forEach(h => obs.observe(h));
  }

  // ── Likes ─────────────────────────────────────────────────────────────────

  let _likeCount = 0;
  let _liked = false;
  let _currentSlug = '';

  async function loadLikes(slug) {
    const token = localStorage.getItem('auth_token');
    const headers = token ? { Authorization: `Bearer ${token}` } : {};
    try {
      const res = await fetch(`${API_BASE}/api/likes/${encodeURIComponent(slug)}`, { headers });
      if (res.ok) {
        const data = await res.json();
        _likeCount = data.count;
        _liked = data.liked;
        renderLikeBtn();
      }
    } catch {}
  }

  function renderLikeBtn() {
    const btn = document.getElementById('like-btn');
    if (!btn) return;
    btn.className = `like-btn${_liked ? ' liked' : ''}`;
    btn.innerHTML = `<svg width="15" height="15" viewBox="0 0 24 24" fill="${_liked ? 'currentColor' : 'none'}" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg> ${_likeCount}`;
  }

  async function handleLike() {
    const token = localStorage.getItem('auth_token');
    if (!token) { window.location.href = '/login'; return; }
    try {
      const res = await fetch(`${API_BASE}/api/likes/${encodeURIComponent(_currentSlug)}`, {
        method: 'POST',
        headers: { Authorization: `Bearer ${token}` },
      });
      if (res.ok) {
        const data = await res.json();
        _likeCount = data.count;
        _liked = data.liked;
        renderLikeBtn();
      } else if (res.status === 401) {
        localStorage.removeItem('auth_token');
        localStorage.removeItem('auth_user');
        window.location.href = '/login';
      }
    } catch {}
  }

  // ── Comments ──────────────────────────────────────────────────────────────

  async function loadComments(slug) {
    const commentList = document.getElementById('comment-list');
    if (!commentList) return;
    try {
      const res = await fetch(`${API_BASE}/api/comments/${encodeURIComponent(slug)}`);
      if (!res.ok) return;
      const comments = await res.json();

      const token = localStorage.getItem('auth_token');
      let currentUserId = null;
      let currentRole = null;
      const userRaw = localStorage.getItem('auth_user');
      if (userRaw) {
        try { const u = JSON.parse(userRaw); currentUserId = u.id; currentRole = u.role; } catch {}
      }

      if (comments.length === 0) {
        commentList.innerHTML = '<p class="text-xs text-[var(--color-text-secondary)] text-center py-4">아직 댓글이 없습니다. 첫 댓글을 남겨보세요!</p>';
      } else {
        commentList.innerHTML = comments.map(c => {
          const date = new Date(c.created_at * 1000).toLocaleDateString('ko-KR', { year: 'numeric', month: 'short', day: 'numeric' });
          const canDelete = currentRole === 'admin' || currentUserId === c.user_id;
          return `<div class="comment-card" id="comment-${c.id}">
            <div class="flex items-start justify-between gap-2">
              <div class="flex items-center gap-2 mb-1.5">
                <span class="w-6 h-6 rounded-full flex items-center justify-center text-white text-xs font-bold flex-shrink-0" style="background:linear-gradient(135deg,#0d9488,#0f766e);">${esc((c.nickname||'?')[0].toUpperCase())}</span>
                <span class="text-xs font-semibold text-[var(--color-text)]">${esc(c.nickname || '익명')}</span>
                <span class="text-xs text-[var(--color-text-secondary)]">${esc(date)}</span>
              </div>
              ${canDelete ? `<button onclick="deleteComment(${c.id})" class="text-xs text-[var(--color-text-secondary)] hover:text-red-500 transition-colors flex-shrink-0">삭제</button>` : ''}
            </div>
            <p class="text-sm text-[var(--color-text)] leading-relaxed">${esc(c.content)}</p>
          </div>`;
        }).join('');
      }
    } catch {}
  }

  function renderCommentForm(slug) {
    const area = document.getElementById('comment-form-area');
    if (!area) return;
    const token = localStorage.getItem('auth_token');
    const userRaw = localStorage.getItem('auth_user');
    let nickname = '';
    if (userRaw) { try { nickname = JSON.parse(userRaw).nickname || ''; } catch {} }

    if (!token) {
      area.innerHTML = `<div class="rounded-xl border border-[var(--color-border)] px-4 py-3 text-sm text-[var(--color-text-secondary)]">
        <a href="/login" class="text-[var(--color-accent)] hover:underline font-medium">로그인</a>하면 댓글을 남길 수 있습니다.
      </div>`;
      return;
    }

    area.innerHTML = `<div class="space-y-2">
      <div class="flex items-center gap-2 mb-2">
        <span class="w-6 h-6 rounded-full flex items-center justify-center text-white text-xs font-bold" style="background:linear-gradient(135deg,#0d9488,#0f766e);">${esc((nickname||'?')[0].toUpperCase())}</span>
        <span class="text-xs font-semibold text-[var(--color-text)]">${esc(nickname)}</span>
      </div>
      <textarea id="comment-input" class="comment-textarea" placeholder="댓글을 입력하세요..." maxlength="1000"></textarea>
      <div class="flex items-center justify-between">
        <span class="text-xs text-[var(--color-text-secondary)]"><span id="comment-char">0</span>/1000</span>
        <button id="comment-btn" class="comment-submit" onclick="submitComment('${slug}')">등록</button>
      </div>
    </div>`;

    document.getElementById('comment-input').addEventListener('input', function() {
      document.getElementById('comment-char').textContent = this.value.length;
    });
  }

  async function submitComment(slug) {
    const input = document.getElementById('comment-input');
    const btn = document.getElementById('comment-btn');
    const content = input?.value?.trim();
    if (!content) return;
    btn.disabled = true;
    btn.textContent = '등록 중...';
    const token = localStorage.getItem('auth_token');
    try {
      const res = await fetch(`${API_BASE}/api/comments/${encodeURIComponent(slug)}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
        body: JSON.stringify({ content }),
      });
      if (res.ok) {
        input.value = '';
        document.getElementById('comment-char').textContent = '0';
        await loadComments(slug);
      } else if (res.status === 401) {
        localStorage.removeItem('auth_token');
        localStorage.removeItem('auth_user');
        window.location.href = '/login';
      }
    } catch {}
    btn.disabled = false;
    btn.textContent = '등록';
  }

  async function deleteComment(id) {
    if (!confirm('댓글을 삭제할까요?')) return;
    const token = localStorage.getItem('auth_token');
    try {
      const res = await fetch(`${API_BASE}/api/comments/id/${id}`, {
        method: 'DELETE',
        headers: { Authorization: `Bearer ${token}` },
      });
      if (res.ok) {
        document.getElementById(`comment-${id}`)?.remove();
        const list = document.getElementById('comment-list');
        if (list && !list.querySelector('[id^="comment-"]')) {
          list.innerHTML = '<p class="text-xs text-[var(--color-text-secondary)] text-center py-4">아직 댓글이 없습니다. 첫 댓글을 남겨보세요!</p>';
        }
      }
    } catch {}
  }

  // ── Main load ─────────────────────────────────────────────────────────────

  async function loadPost() {
    const slug = decodeURIComponent(window.location.hash.slice(1));
    if (!slug) { window.location.href = '/'; return; }
    _currentSlug = slug;

    const container = document.getElementById('post-container');

    try {
      const [postRes, allRes] = await Promise.all([
        fetch(`${API_BASE}/api/posts/${encodeURIComponent(slug)}`),
        fetch(`${API_BASE}/api/posts`),
      ]);

      if (!postRes.ok) throw new Error('Post not found');
      const post = await postRes.json();
      const allPosts = allRes.ok ? (await allRes.json()).filter(p => !p.draft) : [];

      document.title = `${post.title} — xmin.blog`;

      const date = post.date
        ? new Date(post.date).toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })
        : '';

      const tags = (post.tags || []).map(t =>
        `<span class="px-2.5 py-1 rounded-full text-xs text-[var(--color-text-secondary)] bg-[var(--color-bg-secondary)] border border-[var(--color-border)]">${esc(t)}</span>`
      ).join('');

      const idx = allPosts.findIndex(p => p.slug === slug);
      const prev = idx > 0 ? allPosts[idx - 1] : null;
      const next = idx < allPosts.length - 1 ? allPosts[idx + 1] : null;

      const navHtml = (prev || next) ? `
        <div class="flex gap-3 mt-12">
          ${prev ? `<a href="/post#${esc(prev.slug)}" class="post-nav-link"><span class="post-nav-label">← 이전 글</span><span class="post-nav-title">${esc(prev.title)}</span></a>` : '<div class="flex-1"></div>'}
          ${next ? `<a href="/post#${esc(next.slug)}" class="post-nav-link" style="text-align:right;"><span class="post-nav-label">다음 글 →</span><span class="post-nav-title">${esc(next.title)}</span></a>` : '<div class="flex-1"></div>'}
        </div>` : '';

      const wordCount = (post.content || '').replace(/<[^>]+>/g, '').split(/\s+/).length;
      const readTime = Math.max(1, Math.round(wordCount / 200));

      container.innerHTML = `
        <article>
          <header class="mb-10 pb-8 border-b border-[var(--color-border)]">
            <div class="flex flex-wrap items-center gap-2 mb-4">
              ${post.category ? `<a href="/?category=${esc(post.category)}" class="text-xs font-semibold px-3 py-1 rounded-full transition-colors" style="background:rgba(13,148,136,0.1);color:var(--color-accent);">${esc(post.category)}</a>` : ''}
              <span class="text-xs text-[var(--color-text-secondary)]">${esc(date)}</span>
              <span class="text-xs text-[var(--color-text-secondary)]">· ${readTime}분 읽기</span>
            </div>
            <h1 class="text-2xl sm:text-3xl font-bold leading-snug mb-4 tracking-tight" style="font-family:var(--font-display);color:var(--color-text);">${esc(post.title)}</h1>
            <p class="text-base text-[var(--color-text-secondary)] leading-relaxed">${esc(post.description)}</p>
            ${tags ? `<div class="flex flex-wrap gap-2 mt-4">${tags}</div>` : ''}
          </header>

          <div class="prose prose-lg max-w-none" id="prose-content">${renderMarkdown(post.content || '')}</div>

          <!-- Like button -->
          <div class="flex items-center gap-3 mt-10 pt-6 border-t border-[var(--color-border)]">
            <button id="like-btn" class="like-btn" onclick="handleLike()">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
              0
            </button>
            <span class="text-xs text-[var(--color-text-secondary)]">이 글이 도움이 됐나요?</span>
          </div>

          ${navHtml}

          <div class="mt-10 pt-6 border-t border-[var(--color-border)]">
            <a href="/" class="inline-flex items-center gap-1.5 text-sm font-medium text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
              </svg>
              목록으로 돌아가기
            </a>
          </div>
        </article>
      `;

      // Build TOC
      const proseEl = document.getElementById('prose-content');
      if (proseEl) buildToc(proseEl);

      // Load likes
      await loadLikes(slug);

      // Show comments section and load
      const commentsSection = document.getElementById('comments-section');
      if (commentsSection) {
        commentsSection.classList.remove('hidden');
        renderCommentForm(slug);
        await loadComments(slug);
      }

      // Populate sidebar recent posts
      const recentEl = document.getElementById('sidebar-recent');
      if (recentEl && allPosts.length) {
        const recent = allPosts.filter(p => p.slug !== slug).slice(0, 5);
        recentEl.innerHTML = recent.map(p => {
          const d = p.date ? new Date(p.date).toLocaleDateString('ko-KR', { month: 'short', day: 'numeric' }) : '';
          return `<li><a href="/post#${esc(p.slug)}" class="block group">
            <p class="text-xs font-medium text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors line-clamp-2 leading-snug">${esc(p.title)}</p>
            <p class="text-xs text-[var(--color-text-secondary)] mt-0.5">${esc(d)}</p>
          </a></li>`;
        }).join('');
      }

    } catch (err) {
      container.innerHTML = `
        <div class="text-center py-20 text-[var(--color-text-secondary)]">
          <svg class="w-10 h-10 mx-auto mb-3 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
          <p class="text-base font-medium mb-2">글을 찾을 수 없습니다.</p>
          <a href="/" class="text-sm text-[var(--color-accent)] hover:underline">홈으로 돌아가기</a>
        </div>`;
    }
  }

  loadPost();
</script>
