---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="xmin.blog">
  <div class="mx-auto max-w-6xl px-4 sm:px-5 py-8">
    <div class="flex gap-7 items-start">

      <!-- ===== MAIN CONTENT ===== -->
      <main class="flex-1 min-w-0">

        <!-- Terminal hero -->
        <div class="terminal-hero mb-6">
          <div class="terminal-bar">
            <span class="t-dot" style="background:#ef4444;"></span>
            <span class="t-dot" style="background:#eab308;"></span>
            <span class="t-dot" style="background:#22c55e;"></span>
            <span class="terminal-title">xmin@blog: ~</span>
          </div>
          <div class="terminal-body">
            <div class="t-line"><span class="t-prompt">xmin@blog</span><span class="t-sep">:</span><span class="t-path">~</span><span class="t-dollar">$</span> <span class="t-cmd">whoami</span></div>
            <div class="t-out">주수민 (xmin) — 보안 · AI · 개발</div>
            <div class="t-line"><span class="t-prompt">xmin@blog</span><span class="t-sep">:</span><span class="t-path">~</span><span class="t-dollar">$</span> <span class="t-cmd">ls posts/</span></div>
            <div class="t-out" id="hero-count">loading...</div>
            <div class="t-line"><span class="t-prompt">xmin@blog</span><span class="t-sep">:</span><span class="t-path">~</span><span class="t-dollar">$</span> <span class="t-cursor">▊</span></div>
          </div>
        </div>

        <!-- Search bar -->
        <div class="mb-6 relative">
          <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-[var(--color-text-secondary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <input
            id="search-input"
            type="text"
            placeholder="글 검색..."
            class="w-full pl-10 pr-4 py-2.5 rounded-xl text-sm border border-[var(--color-border)] bg-[var(--color-bg-card)] text-[var(--color-text)] placeholder-[var(--color-text-secondary)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)] focus:border-transparent transition-all"
            style="box-shadow: var(--shadow-card);"
          />
        </div>

        <!-- Category filter (horizontal scroll) -->
        <div class="flex gap-2 mb-6 overflow-x-auto pb-1 scrollbar-none" id="category-filter-bar"></div>

        <!-- Post list -->
        <div id="post-list">
          <div class="text-center py-20 text-[var(--color-text-secondary)]" id="loading">
            <div class="inline-block w-6 h-6 border-2 border-[var(--color-accent)] border-t-transparent rounded-full animate-spin mb-3"></div>
            <p class="text-sm">글을 불러오는 중...</p>
          </div>
        </div>
      </main>

      <!-- ===== SIDEBAR ===== -->
      <aside class="w-64 shrink-0 hidden lg:block sticky top-20">

        <!-- Profile card -->
        <div class="sidebar-widget">
          <div class="flex flex-col items-center text-center py-2">
            <div class="w-16 h-16 rounded-full flex items-center justify-center text-white text-xl font-bold mb-3" style="background: linear-gradient(135deg, #0d9488, #0f766e);">
              x
            </div>
            <p class="font-bold text-[var(--color-text)] text-sm">주수민 <span class="font-normal text-[var(--color-text-secondary)]">/ xmin</span></p>
            <p class="text-xs text-[var(--color-text-secondary)] mt-1">보안 · AI</p>
            <div class="flex gap-2 mt-3">
              <a href="https://github.com/xmin-02" target="_blank" rel="noopener" class="p-1.5 rounded-lg bg-[var(--color-bg)] hover:bg-[var(--color-bg-secondary)] transition-colors text-[var(--color-text-secondary)] hover:text-[var(--color-accent)]" aria-label="GitHub">
                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
                </svg>
              </a>
              <a href="https://xmin.sh" target="_blank" rel="noopener" class="p-1.5 rounded-lg bg-[var(--color-bg)] hover:bg-[var(--color-bg-secondary)] transition-colors text-[var(--color-text-secondary)] hover:text-[var(--color-accent)]" aria-label="Portfolio">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/>
                </svg>
              </a>
            </div>
          </div>
        </div>

        <!-- Category list -->
        <div class="sidebar-widget">
          <p class="sidebar-widget-title">카테고리</p>
          <ul id="sidebar-categories" class="space-y-0.5">
            <li><button data-category="all" class="cat-item active w-full flex items-center justify-between px-2.5 py-1.5 rounded-lg text-sm transition-colors hover:bg-[var(--color-bg)] text-left">
              <span>전체</span><span class="text-xs text-[var(--color-text-secondary)]" id="cat-count-all">0</span>
            </button></li>
          </ul>
        </div>

        <!-- Recent posts -->
        <div class="sidebar-widget">
          <p class="sidebar-widget-title">최근 글</p>
          <ul id="sidebar-recent" class="space-y-2.5">
            <li class="text-xs text-[var(--color-text-secondary)]">불러오는 중...</li>
          </ul>
        </div>

      </aside>
    </div>
  </div>
</BaseLayout>

<style is:global>
  .scrollbar-none::-webkit-scrollbar { display: none; }
  .scrollbar-none { -ms-overflow-style: none; scrollbar-width: none; }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }
  .animate-spin {
    animation: spin 0.8s linear infinite;
  }

  .post-card {
    display: block;
    padding: 1.4rem 0;
    border: none;
    border-bottom: 1px solid var(--color-border);
    background: transparent;
    text-decoration: none;
    color: inherit;
    transition: opacity 0.15s;
  }
  .post-card:hover { opacity: 0.92; }
  .post-card:hover .post-card-title { color: var(--color-accent); }
  .post-meta {
    display: flex; gap: 0.55rem; align-items: center;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-text-secondary);
    margin-bottom: 0.45rem;
  }
  .post-cat { color: var(--color-accent); font-weight: 500; }
  .post-meta-mute { color: var(--color-text-secondary); opacity: 0.85; }
  .post-card-title {
    font-size: 1.05rem; font-weight: 600; line-height: 1.45;
    color: var(--color-text); margin-bottom: 0.45rem;
    transition: color 0.2s;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .post-desc {
    font-size: 0.875rem; color: var(--color-text-secondary);
    line-height: 1.6;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }

  .post-card-wrap { position: relative; }
  .admin-card-btns {
    position: absolute; top: 0.5rem; right: 0.5rem;
    display: flex; gap: 0.25rem;
    opacity: 0; transition: opacity 0.15s;
    pointer-events: none;
  }
  .post-card-wrap:hover .admin-card-btns { opacity: 1; pointer-events: auto; }
  .admin-card-btn {
    width: 1.75rem; height: 1.75rem; border-radius: 0.375rem;
    display: flex; align-items: center; justify-content: center;
    background: var(--color-bg-card); border: 1px solid var(--color-border);
    color: var(--color-text-secondary); cursor: pointer;
    text-decoration: none; transition: all 0.15s; padding: 0;
  }
  .admin-card-btn:hover { background: var(--color-accent); color: white; border-color: var(--color-accent); }
  .admin-card-btn.del:hover { background: #ef4444; border-color: #ef4444; }

  /* ── Terminal hero ── */
  .terminal-hero {
    border: 1px solid var(--color-border);
    border-radius: 0.625rem;
    background: var(--color-bg-card);
    overflow: hidden;
    font-family: var(--font-mono);
    box-shadow: var(--shadow-card);
  }
  .terminal-bar {
    display: flex; align-items: center; gap: 0.45rem;
    padding: 0.5rem 0.85rem;
    background: var(--color-bg-secondary);
    border-bottom: 1px solid var(--color-border);
  }
  .t-dot {
    width: 0.7rem; height: 0.7rem; border-radius: 9999px;
    display: inline-block; opacity: 0.85;
  }
  .terminal-title {
    margin-left: 0.5rem;
    font-size: 0.72rem;
    color: var(--color-text-secondary);
    letter-spacing: 0.02em;
  }
  .terminal-body {
    padding: 0.85rem 1rem 0.95rem;
    font-size: 0.82rem;
    line-height: 1.75;
    color: var(--color-text);
  }
  .t-line { white-space: nowrap; overflow-x: auto; }
  .t-prompt { color: var(--color-accent); font-weight: 600; }
  .t-sep { color: var(--color-text-secondary); }
  .t-path { color: var(--color-accent-alt, #10b981); font-weight: 600; }
  .t-dollar { color: var(--color-text-secondary); margin-left: 0.15rem; margin-right: 0.35rem; }
  .t-cmd { color: var(--color-text); }
  .t-out {
    color: var(--color-text-secondary);
    padding-left: 0.15rem;
    padding-bottom: 0.2rem;
  }
  .t-out .tag { color: var(--color-accent); }
  .t-out .num { color: var(--color-accent-bright, var(--color-accent)); font-weight: 600; }
  .t-cursor {
    display: inline-block;
    color: var(--color-accent);
    animation: t-blink 1.1s steps(2, start) infinite;
  }
  @keyframes t-blink { to { opacity: 0; } }
</style>

<script is:inline>
  const API_BASE = 'https://api.xmin.blog';
  let allPosts = [];
  let activeCategory = 'all';
  let searchQuery = '';

  function esc(str) {
    return String(str ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function isAdminUser() {
    try { return JSON.parse(localStorage.getItem('auth_user') || '{}').role === 'admin'; } catch { return false; }
  }

  function renderPosts(posts) {
    const list = document.getElementById('post-list');
    const isAdmin = isAdminUser();
    if (!posts.length) {
      list.innerHTML = `<div class="text-center py-20 text-[var(--color-text-secondary)]">
        <svg class="w-10 h-10 mx-auto mb-3 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
        </svg>
        <p class="text-sm">해당하는 글이 없습니다.</p>
      </div>`;
      return;
    }

    list.innerHTML = posts.map((post) => {
      const date = post.date ? new Date(post.date).toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' }) : '';
      const adminBtns = isAdmin ? `
        <div class="admin-card-btns">
          <a href="/post#${esc(post.slug)}" class="admin-card-btn" title="편집" onclick="event.stopPropagation();">
            <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          </a>
          <button class="admin-card-btn del" title="삭제" onclick="event.preventDefault();event.stopPropagation();adminDeletePost('${esc(post.slug)}');">
            <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
          </button>
        </div>` : '';
      return `
        <div class="post-card-wrap">
          <a href="/post#${esc(post.slug)}" class="post-card" data-category="${esc(post.category)}">
            <div class="post-meta">
              ${post.category ? `<span class="post-cat">[${esc(post.category)}]</span>` : ''}
              <span>${esc(date)}</span>
            </div>
            <h2 class="post-card-title">${esc(post.title)}</h2>
            <p class="post-desc">${esc(post.description)}</p>
          </a>
          ${adminBtns}
        </div>
      `;
    }).join('');
  }

  async function adminDeletePost(slug) {
    if (!confirm(`"${slug}" 글을 삭제할까요?`)) return;
    const token = localStorage.getItem('auth_token');
    try {
      const res = await fetch(`${API_BASE}/api/posts/${encodeURIComponent(slug)}`, {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
        body: JSON.stringify({}),
      });
      if (res.ok) {
        allPosts = allPosts.filter(p => p.slug !== slug);
        filterAndSearch();
      } else {
        const d = await res.json();
        alert('삭제 실패: ' + (d.error || res.status));
      }
    } catch (e) {
      alert('오류: ' + e.message);
    }
  }

  function filterAndSearch() {
    let filtered = allPosts;
    if (activeCategory !== 'all') {
      filtered = filtered.filter(p => p.category === activeCategory);
    }
    if (searchQuery) {
      const q = searchQuery.toLowerCase();
      filtered = filtered.filter(p =>
        (p.title || '').toLowerCase().includes(q) ||
        (p.description || '').toLowerCase().includes(q) ||
        (p.category || '').toLowerCase().includes(q)
      );
    }
    renderPosts(filtered);

    // Update active state on category filter bar
    document.querySelectorAll('.filter-btn').forEach(btn => {
      btn.classList.toggle('active', btn.dataset.category === activeCategory);
    });
    document.querySelectorAll('.cat-item').forEach(btn => {
      btn.classList.toggle('active', btn.dataset.category === activeCategory);
    });
  }

  async function loadPosts() {
    try {
      const res = await fetch(`${API_BASE}/api/posts`);
      if (!res.ok) throw new Error('API error');
      const data = await res.json();
      allPosts = data.filter(p => !p.draft);

      document.getElementById('loading')?.remove();

      // Build categories
      const catCounts = {};
      allPosts.forEach(p => {
        if (p.category) catCounts[p.category] = (catCounts[p.category] || 0) + 1;
      });
      const cats = Object.keys(catCounts);

      // Terminal hero count line
      const heroCount = document.getElementById('hero-count');
      if (heroCount) {
        const tagStr = cats.length
          ? cats.map(c => `<span class="tag">[${esc(c)}]</span>`).join(' ')
          : '';
        heroCount.innerHTML = `<span class="num">${allPosts.length}</span> posts ${tagStr ? '· tags: ' + tagStr : ''}`;
      }

      // Horizontal filter bar (top of main)
      const filterBar = document.getElementById('category-filter-bar');
      filterBar.innerHTML = ['전체', ...cats].map(cat => {
        const isAll = cat === '전체';
        const key = isAll ? 'all' : cat;
        return `<button data-category="${esc(key)}" class="filter-btn shrink-0 px-3.5 py-1.5 rounded-full text-sm font-medium transition-all border border-[var(--color-border)] bg-[var(--color-bg-card)] text-[var(--color-text-secondary)] whitespace-nowrap ${isAll ? 'active' : ''}">${esc(cat)}</button>`;
      }).join('');

      filterBar.querySelectorAll('.filter-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          activeCategory = btn.dataset.category;
          filterAndSearch();
        });
      });

      // Sidebar category list
      const sidebarCats = document.getElementById('sidebar-categories');
      const allCount = document.getElementById('cat-count-all');
      if (allCount) allCount.textContent = allPosts.length;

      cats.forEach(cat => {
        const li = document.createElement('li');
        li.innerHTML = `<button data-category="${esc(cat)}" class="cat-item w-full flex items-center justify-between px-2.5 py-1.5 rounded-lg text-sm transition-colors hover:bg-[var(--color-bg)] text-left">
          <span>${esc(cat)}</span><span class="text-xs text-[var(--color-text-secondary)]">${catCounts[cat]}</span>
        </button>`;
        sidebarCats?.appendChild(li);
      });

      // Update sidebar "전체" button count
      const allBtn = sidebarCats?.querySelector('[data-category="all"]');
      if (allBtn) {
        const span = allBtn.querySelector('span:last-child');
        if (span) span.textContent = allPosts.length;
      }

      sidebarCats?.querySelectorAll('.cat-item').forEach(btn => {
        btn.addEventListener('click', () => {
          activeCategory = btn.dataset.category;
          filterAndSearch();
        });
      });

      // Sidebar recent posts
      const recentEl = document.getElementById('sidebar-recent');
      if (recentEl) {
        const recent = allPosts.slice(0, 5);
        recentEl.innerHTML = recent.map(p => {
          const date = p.date ? new Date(p.date).toLocaleDateString('ko-KR', { month: 'short', day: 'numeric' }) : '';
          return `<li>
            <a href="/post#${esc(p.slug)}" class="block group">
              <p class="text-xs font-medium text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors line-clamp-2 leading-snug">${esc(p.title)}</p>
              <p class="text-xs text-[var(--color-text-secondary)] mt-0.5">${esc(date)}</p>
            </a>
          </li>`;
        }).join('');
      }

      // Search
      const searchInput = document.getElementById('search-input');
      searchInput?.addEventListener('input', e => {
        searchQuery = e.target.value.trim();
        filterAndSearch();
      });

      renderPosts(allPosts);

    } catch (err) {
      const loading = document.getElementById('loading');
      if (loading) {
        loading.innerHTML = '<p class="text-sm">글을 불러오지 못했습니다.</p>';
      }
      console.error(err);
    }
  }

  loadPosts();
</script>
