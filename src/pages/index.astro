---
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categories = ['전체', ...new Set(posts.map(p => p.data.category))];
---

<BaseLayout title="xmin.blog">
  <section class="mx-auto max-w-3xl px-6 py-16">
    <div class="mb-12">
      <h1 class="text-4xl font-bold tracking-tight mb-3" style="font-family: var(--font-display);">
        Blog
      </h1>
      <p class="text-lg text-[var(--color-text-secondary)]">
        보안, AI, 개발에 대한 이야기
      </p>
    </div>

    <!-- Category Filter -->
    <div class="flex flex-wrap gap-2 mb-10" id="category-filter">
      {categories.map((cat, i) => (
        <button
          data-category={cat === '전체' ? 'all' : cat}
          class:list={[
            'filter-btn px-4 py-1.5 rounded-full text-sm font-medium border border-[var(--color-border)] transition-all duration-200',
            i === 0 ? 'active' : 'text-[var(--color-text-secondary)]',
          ]}
        >
          {cat}
        </button>
      ))}
    </div>

    <!-- Post List -->
    <div class="grid gap-4" id="post-list">
      {posts.map(post => (
        <div data-category={post.data.category}>
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            category={post.data.category}
            tags={post.data.tags}
            slug={post.id}
          />
        </div>
      ))}
    </div>

    {posts.length === 0 && (
      <div class="text-center py-20 text-[var(--color-text-secondary)]">
        <p class="text-lg">아직 작성된 글이 없습니다.</p>
        <p class="text-sm mt-2">곧 새로운 글이 올라올 예정입니다.</p>
      </div>
    )}
  </section>
</BaseLayout>

<style is:global>
  .filter-btn.active {
    background-color: var(--color-primary);
    color: white;
    border-color: var(--color-primary);
  }
</style>

<script is:inline>
  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      const cat = btn.dataset.category;
      document.querySelectorAll('#post-list > div').forEach(card => {
        card.style.display = (cat === 'all' || card.dataset.category === cat) ? '' : 'none';
      });
    });
  });
</script>
