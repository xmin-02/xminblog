---
import BaseLayout from './BaseLayout.astro';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    date: Date;
    category: string;
    tags: string[];
  };
}

const { frontmatter } = Astro.props;
const formattedDate = frontmatter.date.toISOString().split('T')[0];
---

<BaseLayout title={`${frontmatter.title} — xmin.blog`} description={frontmatter.description}>
  <article class="mx-auto max-w-3xl px-6 py-16">
    <header class="mb-12">
      <div class="flex items-center gap-3 mb-4">
        <span class="px-3 py-1 rounded-full text-xs font-medium bg-primary/10 text-primary">
          {frontmatter.category}
        </span>
        <time class="text-sm font-mono text-[var(--color-text-secondary)]">
          {formattedDate}
        </time>
      </div>
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight mb-4" style="font-family: var(--font-display);">
        {frontmatter.title}
      </h1>
      <p class="text-lg text-[var(--color-text-secondary)]">
        {frontmatter.description}
      </p>
      {frontmatter.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {frontmatter.tags.map(tag => (
            <span class="px-2 py-1 rounded-full text-xs text-[var(--color-text-secondary)] bg-[var(--color-bg-secondary)] border border-[var(--color-border)]">
              {tag}
            </span>
          ))}
        </div>
      )}
      <hr class="mt-8 border-[var(--color-border)]" />
    </header>
    <div class="prose prose-lg max-w-none">
      <slot />
    </div>
    <footer class="mt-16 pt-8 border-t border-[var(--color-border)]">
      <a
        href="/"
        class="inline-flex items-center gap-2 text-sm font-medium text-[var(--color-text-secondary)] hover:text-primary transition-colors"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        목록으로 돌아가기
      </a>
    </footer>
  </article>
</BaseLayout>
